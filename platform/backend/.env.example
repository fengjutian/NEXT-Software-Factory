# Database
DATABASE_URL=postgresql+asyncpg://factory:factory_dev@localhost:5432/ai_factory

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM
LLM_API_KEY=sk-ant-...
LLM_PROVIDER=claude
